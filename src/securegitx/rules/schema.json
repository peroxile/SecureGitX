{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "SecureGitX Rule Bundle",
    "type": "object",
    "required": ["version", "rules"],
    "additionalProperties": false,
    "properties": {
      "version": {
        "type": "string",
        "description": "Semantic version of this rule bundle"
      },
      "rules": {
        "type": "array",
        "items": { "$ref": "#/definitions/Rule" }
      }
    },
    "definitions": {
      "Rule": {
        "type": "object",
        "required": ["id", "name", "pattern", "type", "severity"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "pattern": "^SGX[0-9]{3}$" },
          "name":        { "type": "string" },
          "description": { "type": "string" },
          "pattern":     { "type": "string" },
          "type":        { "type": "string", "enum": ["filename", "content"] },
          "severity":    { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "tags":        { "type": "array", "items": { "type": "string" } },
          "enabled":     { "type": "boolean" },
          "case_sensitive": { "type": "boolean" },
          "examples":    { "type": "array", "items": { "type": "string" } },
          "non_examples":{ "type": "array", "items": { "type": "string" } },
          "remediation": { "type": "string" }
        }
      }
    }
  }